# ==============================================================================
# HISTORY  (equivalente a la seccion HISTORY del bashrc)
# ==============================================================================

HISTSIZE=5000
SAVEHIST=10000                  # ≈ HISTFILESIZE de bash
HISTFILE="$HOME/.zsh_history"   # bash usa ~/.bash_history implicito; zsh hay que setearlo
setopt APPEND_HISTORY INC_APPEND_HISTORY   # ≈ shopt histappend (escribe incremental)
