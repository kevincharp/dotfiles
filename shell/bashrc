# herramienta Rust. Fuente unica versionada: rustup ademas mete esta
# linea en ~/.profile y ~/.bash_profile, pero esos se mantienen limpios y la
# carga vive aca (idempotente: solo si el archivo existe).
[[ -f "$HOME/.cargo/env" ]] && . "$HOME/.cargo/env"

# ==============================================================================
# BLE.SH — syntax highlighting + autosugerencias en la linea de input
# ------------------------------------------------------------------------------
# Equivalente bash de PSReadLine (profile.ps1): colorea cada token mientras
# escribis y sugiere desde el historial. La paleta (mas abajo) replica los
# Colors de PSReadLine para tener paridad Linux/Windows.
#
# OJO con el orden: se sourcea con el metodo de attach por defecto (=prompt),
# que adjunta ble.sh recien en el primer prompt via PROMPT_COMMAND. NO usar
# '--noattach' + 'ble-attach' manual: empeora el redibujado del prompt al
# adjuntarse. El prompt duplicado se resolvio ademas quitando el newline inicial
# del tema (ver claude-code.omp.json) + bleopt prompt_command_changes_layout.
# ==============================================================================

_BLESH_DIR="$HOME/.local/share/blesh"
if [[ $- == *i* && -f "$_BLESH_DIR/ble.sh" ]]; then
    source "$_BLESH_DIR/ble.sh"
fi

# ==============================================================================
# PROMPT — oh-my-posh con tema spaceship
# ==============================================================================

if command -v oh-my-posh &>/dev/null; then
    if [[ "$IS_WINDOWS" == true ]]; then
        _omp_theme="${POSH_THEMES_PATH:-$HOME/AppData/Local/Programs/oh-my-posh/themes}/claude-code.omp.json"
        _omp_fallback="${POSH_THEMES_PATH:-$HOME/AppData/Local/Programs/oh-my-posh/themes}/spaceship.omp.json"
    else
        _omp_theme="${XDG_CONFIG_HOME:-$HOME/.config}/oh-my-posh/themes/claude-code.omp.json"
        _omp_fallback=""
    fi
    if [[ -f "$_omp_theme" ]]; then
        eval "$(oh-my-posh init bash --config "$_omp_theme")"
    elif [[ -n "$_omp_fallback" && -f "$_omp_fallback" ]]; then
        eval "$(oh-my-posh init bash --config "$_omp_fallback")"
    else
        eval "$(oh-my-posh init bash --config spaceship)"
    fi
    unset _omp_theme _omp_fallback
else
    echo "oh-my-posh no instalado"
    echo "  Windows: winget install JanDeDobbeleer.OhMyPosh"
    echo "  Linux:   curl -s https://ohmyposh.dev/install.sh | bash -s"
fi

