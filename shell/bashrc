# ==============================================================================
# FZF (busqueda difusa — Ctrl+R para historial)
# ==============================================================================

if command -v fzf &>/dev/null; then
    # Cargar keybindings (Ctrl+R historial, Ctrl+T, Alt+C) + completions.
    # fzf >= 0.48 expone todo via 'fzf --bash' (portable, sin adivinar rutas).
    if fzf --bash &>/dev/null; then
        eval "$(fzf --bash)"
    # Fallback para versiones viejas: las rutas varian por distro.
    elif [[ -f /usr/share/fzf/shell/key-bindings.bash ]]; then   # Fedora 38+
        . /usr/share/fzf/shell/key-bindings.bash
    elif [[ -f /usr/share/fzf/key-bindings.bash ]]; then          # Arch / otros
        . /usr/share/fzf/key-bindings.bash
    elif [[ -f /usr/share/doc/fzf/examples/key-bindings.bash ]]; then  # Debian/Ubuntu
        . /usr/share/doc/fzf/examples/key-bindings.bash
    elif [[ -f ~/.fzf.bash ]]; then                               # instalador git (Windows)
        . ~/.fzf.bash
    fi

    export FZF_DEFAULT_OPTS="--height 40% --border rounded --layout=reverse --prompt ' ' \
--color=bg+:#3A2E2A,bg:#1E1A18,spinner:#D4874E,hl:#C79BFF \
--color=fg:#E8E0D4,header:#7AB8FF,info:#FFDF61,pointer:#D4874E \
--color=marker:#86E89A,fg+:#E8E0D4,prompt:#D4874E,hl+:#E8935A \
--color=border:#5C4A44,label:#A89890,query:#E8E0D4"
    export FZF_CTRL_R_OPTS='--prompt " historial> "'
fi

# ==============================================================================
# FLECHA ARRIBA → lista de historial estilo PSReadLine ListView (espejo del zshrc)
# ------------------------------------------------------------------------------
# Mismo comportamiento que en zsh: ↑ abre fzf con el historial en lista vertical,
# solo el comando, filtrado por PREFIJO con lo ya tipeado. Ctrl+R sigue siendo la
# busqueda difusa (bloque FZF). En bash el editor de linea lo maneja ble.sh, que
# captura las teclas con SU sistema ('ble-bind'), no con el 'bind' de readline:
# por eso se detecta ble.sh y, si no esta, se cae al 'bind -x' clasico.
# ==============================================================================
if [[ $- == *i* ]] && command -v fzf &>/dev/null; then
    # Construye la linea: historial reciente primero, sin numero de evento,
    # deduplicado, filtrado por prefijo ("^") con lo ya escrito.
    _fzf_history_widget() {
        local query="$READLINE_LINE" selection
        selection=$(history | tac \
            | sed 's/^[[:space:]]*[0-9]*[[:space:]]*//' \
            | awk '!seen[$0]++' \
            | fzf ${query:+--query="^$query"} --no-sort --scheme=history \
                  --tiebreak=index --prompt=' historial> ')
        if [[ -n "$selection" ]]; then
            READLINE_LINE="$selection"
            READLINE_POINT=${#READLINE_LINE}
        fi
    }
    if [[ -n "${BLE_VERSION-}" ]]; then
        # ble.sh activo: 'ble-bind -x' ejecuta una funcion bash que puede
        # leer/escribir READLINE_LINE/POINT (igual que 'bind -x' de readline).
        # ble.sh aplica estos binds al adjuntarse en el primer prompt.
        ble-bind -x 'up' '_fzf_history_widget' 2>/dev/null
    else
        # readline puro (sin ble.sh): bind -x da acceso a READLINE_LINE.
        bind -x '"\e[A": _fzf_history_widget' 2>/dev/null
        bind -x '"\eOA": _fzf_history_widget' 2>/dev/null
    fi
fi

