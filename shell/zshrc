# ==============================================================================
#   zshrc — Perfil unificado Kevin Charpentier (zsh)
#   Espejo idiomatico de bashrc. Solo Linux/macOS (zsh no corre en Git Bash;
#   en Windows el shell unificado es PowerShell + PSReadLine, ver profile.ps1).
#
#   PARIDAD: cualquier funcion/alias que se toque aca debe replicarse en bashrc
#   (y en profile.ps1 cuando aplique). test-bootstrap.sh verifica la paridad.
#
#   Diferencias bash→zsh documentadas:
#     - HISTTIMEFORMAT no existe; el equivalente es 'setopt EXTENDED_HISTORY'
#       (se ve con 'history -i').
#     - 'shopt checkwinsize' no tiene equivalente: zsh recalcula LINES/COLUMNS solo.
#     - 'shopt cdspell' ≈ 'setopt CORRECT' (aproximado, no 1:1).
#     - ~/.zshrc lo carga zsh solo en shells interactivos; ~/.zprofile NO lo sourcea
#       (a diferencia de bash_profile, que sourcea bashrc a mano).
# ==============================================================================

# ==============================================================================
# OS DETECTION
# ==============================================================================

case "$(uname -s)" in
    Darwin*) IS_MACOS=true  ;;
    *)       IS_MACOS=false ;;
esac

# ==============================================================================
# TMUX — autoarranque con sesion unica 'main' persistente
# ------------------------------------------------------------------------------
# Espejo del bloque TMUX en bashrc (paridad). Va ANTES de oh-my-posh: si vamos a
# saltar a tmux no tiene sentido inicializar prompt/plugins en la shell de afuera
# (tmux relanza este mismo zshrc adentro, donde si corren).
#
# Logica:
#   - Solo en shell interactiva ([[ -o interactive ]]) y si NO estamos ya dentro.
#   - 'attach -t main' reusa la sesion existente; '|| new -s main' la crea.
#     Siempre es la MISMA sesion main → no se acumulan sesiones zombi.
#   - El 'exit' final cierra la terminal al salir de tmux (sin loop de rearranque).
# Para desactivar, exportar DOTFILES_NO_TMUX=1 antes de abrir la shell.
# (No hace falta chequear Windows: zsh no corre en Git Bash, ver header.)
# ==============================================================================
if [[ -o interactive ]] && [[ -z "$TMUX" ]] && [[ -z "$DOTFILES_NO_TMUX" ]] \
   && command -v tmux &>/dev/null; then
    tmux attach -t main 2>/dev/null || tmux new -s main
    exit
fi

# ==============================================================================
# PATH — Agregar ~/.local/bin (para oh-my-posh, zoxide, etc.)
# ==============================================================================

if [[ -d "$HOME/.local/bin" ]]; then
    export PATH="$HOME/.local/bin:$PATH"
fi

# opencode (instalador SST) deja el binario en ~/.opencode/bin
if [[ -d "$HOME/.opencode/bin" ]]; then
    export PATH="$HOME/.opencode/bin:$PATH"
fi

# ==============================================================================
# PROMPT — oh-my-posh con tema claude-code
# ==============================================================================

if command -v oh-my-posh &>/dev/null; then
    _omp_theme="${XDG_CONFIG_HOME:-$HOME/.config}/oh-my-posh/themes/claude-code.omp.json"
    if [[ -f "$_omp_theme" ]]; then
        eval "$(oh-my-posh init zsh --config "$_omp_theme")"
    else
        eval "$(oh-my-posh init zsh --config spaceship)"
    fi
    unset _omp_theme
else
    echo "oh-my-posh no instalado"
    echo "  Linux/macOS: curl -s https://ohmyposh.dev/install.sh | bash -s"
fi

