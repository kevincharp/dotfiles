# ==============================================================================

# --- claude-smg: lanzar Claude Code con perfil Bedrock de SMG ---
claude-smg() {
    # El perfil AWS se toma de $CLAUDE_SMG_AWS_PROFILE (defini en ~/.env); fallback 'default'
    export CLAUDE_CODE_USE_BEDROCK="1"
    export AWS_PROFILE="${CLAUDE_SMG_AWS_PROFILE:-default}"
    export AWS_REGION="${CLAUDE_SMG_AWS_REGION:-us-east-1}"
    # Modelos Bedrock (inference profiles us.*). Overridables desde ~/.env.
    export ANTHROPIC_MODEL="${CLAUDE_SMG_MODEL:-us.anthropic.claude-opus-4-8}"
    export ANTHROPIC_SMALL_FAST_MODEL="${CLAUDE_SMG_SMALL_MODEL:-us.anthropic.claude-haiku-4-5-20251001-v1:0}"

    if ! aws sts get-caller-identity --profile "$AWS_PROFILE" >/dev/null 2>&1; then
        echo "Sesion SSO caducada o ausente, ejecutando: aws sso login --profile $AWS_PROFILE"
        aws sso login --profile "$AWS_PROFILE" || {
            echo "Fallo el login SSO, abortando." >&2
            unset CLAUDE_CODE_USE_BEDROCK AWS_PROFILE AWS_REGION ANTHROPIC_MODEL ANTHROPIC_SMALL_FAST_MODEL
            return 1
        }
    fi

    claude "$@"
    unset CLAUDE_CODE_USE_BEDROCK AWS_PROFILE AWS_REGION ANTHROPIC_MODEL ANTHROPIC_SMALL_FAST_MODEL
}

# ==============================================================================
# SPF — listado de funciones/aliases del bashrc
# ==============================================================================

# Listar funciones y aliases definidos en este bashrc.
# Uso: spf [filtro]
# Ejemplo: spf git   (filtra por nombre)
# Ejemplo: spf       (lista todo)
spf() {
    local filter="${1:-}"
    local bashrc_file="${BASH_SOURCE[0]:-$HOME/.bashrc}"

    echo "=== Funciones ==="
    echo ""

    # Extraer funciones con su comentario precedente (linea # --- ...)
    local in_block=false
    local desc=""
    while IFS= read -r line; do
        if [[ "$line" =~ ^#\ ---\ (.+)\ ---$ ]]; then
            desc="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^([a-zA-Z_][a-zA-Z0-9_-]*)\(\) ]]; then
            local fname="${BASH_REMATCH[1]}"
            if [[ -z "$filter" ]] || [[ "$fname" == *"$filter"* ]] || [[ "$desc" == *"$filter"* ]]; then
                printf "  %-16s %s\n" "$fname" "$desc"
            fi
            desc=""
        else
            if [[ ! "$line" =~ ^# ]]; then
                desc=""
            fi
        fi
    done < "$bashrc_file"

    echo ""
    echo "=== Aliases ==="
    echo ""

    # Extraer aliases
    while IFS= read -r line; do
        if [[ "$line" =~ ^alias\ ([a-zA-Z_][a-zA-Z0-9_-]*)=\'(.+)\'$ ]] || [[ "$line" =~ ^alias\ ([a-zA-Z_][a-zA-Z0-9_-]*)=\"(.+)\"$ ]]; then
            local aname="${BASH_REMATCH[1]}"
            local aval="${BASH_REMATCH[2]}"
            if [[ -z "$filter" ]] || [[ "$aname" == *"$filter"* ]] || [[ "$aval" == *"$filter"* ]]; then
                printf "  %-16s → %s\n" "$aname" "$aval"
            fi
        fi
    done < "$bashrc_file"
}

