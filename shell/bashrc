# ==============================================================================
# ICLOUD DRIVE — montar/desmontar via rclone (backend iclouddrive)
# ------------------------------------------------------------------------------
# rclone expone iCloud Drive como una carpeta local (equivalente Linux al cliente
# iCloud de Windows). El remote 'icloud' se configura UNA sola vez con
# 'rclone config' (pide Apple ID + codigo 2FA del iPhone). El token resultante
# queda en ~/.config/rclone/rclone.conf y NO se versiona por ser sensible.
# Solo Linux (usa FUSE/fusermount3). Overridables: $ICLOUD_REMOTE, $ICLOUD_MOUNT.
# ==============================================================================

ICLOUD_REMOTE="${ICLOUD_REMOTE:-icloud}"
ICLOUD_MOUNT="${ICLOUD_MOUNT:-$HOME/icloud}"
export ICLOUD_REMOTE ICLOUD_MOUNT

# Verifica que rclone este instalado y el remote configurado. Devuelve 1 si no.
_icloud_check() {
    if ! command -v rclone &>/dev/null; then
        echo "rclone no esta instalado (bootstrap: bash install.sh --tools=rclone)" >&2
        return 1
    fi
    if ! rclone listremotes 2>/dev/null | grep -qx "${ICLOUD_REMOTE}:"; then
        echo "Remote '${ICLOUD_REMOTE}' no configurado. Ejecuta: rclone config" >&2
        return 1
    fi
}

# --- icloud-mount: montar iCloud Drive en ~/icloud ---
icloud-mount() {
    _icloud_check || return 1
    if mountpoint -q "$ICLOUD_MOUNT" 2>/dev/null; then
        echo "Ya montado en $ICLOUD_MOUNT"
        return 0
    fi
    mkdir -p "$ICLOUD_MOUNT"
    rclone mount "${ICLOUD_REMOTE}:" "$ICLOUD_MOUNT" --vfs-cache-mode full --daemon \
        && echo "iCloud Drive montado en $ICLOUD_MOUNT"
}

# --- icloud-umount: desmontar iCloud Drive ---
icloud-umount() {
    if mountpoint -q "$ICLOUD_MOUNT" 2>/dev/null; then
        fusermount3 -u "$ICLOUD_MOUNT" 2>/dev/null || fusermount -u "$ICLOUD_MOUNT"
        echo "Desmontado $ICLOUD_MOUNT"
    else
        echo "No estaba montado: $ICLOUD_MOUNT"
    fi
}

# --- icloud-ls: listar una carpeta de iCloud sin descargar nada ---
# Uso: icloud-ls [carpeta]   (sin argumento lista la raiz)
icloud-ls() {
    _icloud_check || return 1
    rclone lsf "${ICLOUD_REMOTE}:${1:-}"
}

# --- icloud-pull: copiar una carpeta de iCloud al destino (incremental) ---
# Mas rapido que el explorador: descarga en paralelo y sin generar miniaturas.
# Uso: icloud-pull <carpeta-remota> <destino-local>
# Ej:  icloud-pull images /run/media/$USER/disco-externo/Fotos
icloud-pull() {
    local src="${1:?Uso: icloud-pull <carpeta-remota> <destino-local>}"
    local dst="${2:?Uso: icloud-pull <carpeta-remota> <destino-local>}"
    _icloud_check || return 1
    rclone copy "${ICLOUD_REMOTE}:${src}" "$dst" -P --transfers 8
}

# ==============================================================================
# SPF — listado de funciones/aliases del bashrc
# ==============================================================================

# Listar funciones y aliases definidos en este bashrc.
# Uso: spf [filtro]
# Ejemplo: spf git   (filtra por nombre)
# Ejemplo: spf       (lista todo)
spf() {
    local filter="${1:-}"
    local bashrc_file="${BASH_SOURCE[0]:-$HOME/.bashrc}"

    echo "=== Funciones ==="
    echo ""

    # Extraer funciones con su comentario precedente (linea # --- ...)
    local in_block=false
    local desc=""
    while IFS= read -r line; do
        if [[ "$line" =~ ^#\ ---\ (.+)\ ---$ ]]; then
            desc="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^([a-zA-Z_][a-zA-Z0-9_-]*)\(\) ]]; then
            local fname="${BASH_REMATCH[1]}"
            if [[ -z "$filter" ]] || [[ "$fname" == *"$filter"* ]] || [[ "$desc" == *"$filter"* ]]; then
                printf "  %-16s %s\n" "$fname" "$desc"
            fi
            desc=""
        else
            if [[ ! "$line" =~ ^# ]]; then
                desc=""
            fi
        fi
    done < "$bashrc_file"

    echo ""
    echo "=== Aliases ==="
    echo ""

    # Extraer aliases
    while IFS= read -r line; do
        if [[ "$line" =~ ^alias\ ([a-zA-Z_][a-zA-Z0-9_-]*)=\'(.+)\'$ ]] || [[ "$line" =~ ^alias\ ([a-zA-Z_][a-zA-Z0-9_-]*)=\"(.+)\"$ ]]; then
            local aname="${BASH_REMATCH[1]}"
            local aval="${BASH_REMATCH[2]}"
            if [[ -z "$filter" ]] || [[ "$aname" == *"$filter"* ]] || [[ "$aval" == *"$filter"* ]]; then
                printf "  %-16s → %s\n" "$aname" "$aval"
            fi
        fi
    done < "$bashrc_file"
}

# ==============================================================================
# PTYXIS — sincronizar config de la terminal (dconf <-> repo)
# ==============================================================================
# Ptyxis guarda su config en dconf (no en un archivo), por eso no se puede
# symlinkear como Windows Terminal. Estos helpers vuelcan/restauran el dump
# versionado en ~/.dotfiles/terminal/ptyxis.dconf.

# --- ptyxis-save: volcar la config actual de Ptyxis al repo ---
ptyxis-save() {
    local dump="$HOME/.dotfiles/terminal/ptyxis.dconf"
    if ! command -v dconf &>/dev/null; then
        echo "dconf no esta disponible"
        return 1
    fi
    dconf dump /org/gnome/Ptyxis/ > "$dump" && echo "Ptyxis -> $dump"
}

# --- ptyxis-load: restaurar la config de Ptyxis desde el repo ---
ptyxis-load() {
    local dump="$HOME/.dotfiles/terminal/ptyxis.dconf"
    if ! command -v dconf &>/dev/null; then
        echo "dconf no esta disponible"
        return 1
    fi
    if [[ ! -f "$dump" ]]; then
        echo "No existe $dump"
        return 1
    fi
    dconf load /org/gnome/Ptyxis/ < "$dump" && echo "Restaurado desde $dump"
}

# ==============================================================================
# GNOME — sincronizar configuracion del escritorio (dconf <-> repo)
# ==============================================================================
# GNOME guarda atajos, dock, extensiones, etc. en dconf (no en archivos), por
# eso no se puede symlinkear. gnome-save vuelca al repo; gnome-load restaura.
#
# Para versionar una rama nueva: agregala a _GNOME_DCONF_MAP con el formato
# "ruta/dconf/:archivo.dconf". 'dconf load' es ADITIVO (solo escribe las claves
# del archivo, no borra el resto), por eso shell.dconf puede traer solo
# favorite-apps y enabled-extensions sin pisar el resto de /org/gnome/shell/.

# Mapa "rama dconf : archivo en gnome/" (relativo a ~/.dotfiles/gnome/)
_GNOME_DCONF_MAP=(
    "/org/gnome/settings-daemon/plugins/media-keys/:media-keys.dconf"
    "/org/gnome/desktop/wm/keybindings/:wm-keybindings.dconf"
    "/org/gnome/shell/extensions/dash-to-dock/:dash-to-dock.dconf"
    "/org/gnome/shell/extensions/blur-my-shell/:blur-my-shell.dconf"
    "/org/gnome/GPaste/:gpaste.dconf"
    "/org/gnome/shell/:shell.dconf"
)

# --- gnome-save: volcar la config de GNOME al repo (todas las ramas) ---
gnome-save() {
    local dir="$HOME/.dotfiles/gnome"
    if ! command -v dconf &>/dev/null; then
        echo "dconf no esta disponible"
        return 1
    fi
    local entry path file
    for entry in "${_GNOME_DCONF_MAP[@]}"; do
        path="${entry%%:*}"
        file="${entry##*:}"
        # shell.dconf se mantiene a mano (solo claves selectas), no se vuelca entero
        if [[ "$file" == "shell.dconf" ]]; then
            echo "omitido  $file (editar a mano: rama ruidosa)"
            continue
        fi
        dconf dump "$path" > "$dir/$file" && echo "guardado $file"
    done
}

# --- gnome-load: restaurar la config de GNOME desde el repo (todas las ramas) ---
gnome-load() {
    local dir="$HOME/.dotfiles/gnome"
    if ! command -v dconf &>/dev/null; then
        echo "dconf no esta disponible"
        return 1
    fi
    local entry path file
    for entry in "${_GNOME_DCONF_MAP[@]}"; do
        path="${entry%%:*}"
        file="${entry##*:}"
        if [[ -f "$dir/$file" ]]; then
            dconf load "$path" < "$dir/$file" && echo "restaurado $file"
        else
            echo "falta    $file (no existe en el repo)"
        fi
    done
}

# ==============================================================================
# BATERIA — limite de carga (Lenovo conservation mode)
# ==============================================================================
# El ThinkBook usa el "conservation mode" del EC (driver ideapad_laptop): un
# interruptor on/off que topa la carga en ~80% para cuidar la bateria. Es el
# MISMO ajuste que Lenovo Vantage en Windows (vive en el firmware, persiste entre
# SO). NO es un porcentaje configurable: solo on (topa ~80%) u off (carga al 100%).
# La ruta sysfs cuelga del dispositivo VPC2004 (no de BAT0) y la numeracion PCI
# puede variar, por eso se resuelve con 'find' en vez de hardcodearla.

# --- battery-limit: ver/activar/desactivar el tope de carga -------------------
# Uso: battery-limit            -> status (alias de 'status')
#      battery-limit status     -> estado + carga actual
#      battery-limit on         -> activar tope (~80%), cuida la bateria
#      battery-limit off        -> desactivar tope, carga al 100% (p.ej. viaje)
battery-limit() {
    local cm
    cm=$(find /sys/devices -name conservation_mode 2>/dev/null | head -1)
    if [[ -z "$cm" ]]; then
        echo "conservation_mode no disponible (¿no es un Lenovo ideapad?)"
        return 1
    fi
    case "${1:-status}" in
        on)
            echo 1 | sudo tee "$cm" >/dev/null && echo "Tope de carga ACTIVADO (~80%)"
            ;;
        off)
            echo 0 | sudo tee "$cm" >/dev/null && echo "Tope de carga DESACTIVADO (carga al 100%)"
            ;;
        status)
            local cap; cap=$(cat /sys/class/power_supply/BAT0/capacity 2>/dev/null)
            local st;  st=$(cat /sys/class/power_supply/BAT0/status 2>/dev/null)
            if [[ "$(cat "$cm")" == "1" ]]; then
                echo "Tope: ON (~80%)  |  carga: ${cap}%  |  estado: ${st}"
            else
                echo "Tope: OFF (100%)  |  carga: ${cap}%  |  estado: ${st}"
            fi
            ;;
        *)
            echo "Uso: battery-limit [status|on|off]"
            return 1
            ;;
    esac
}

# --- flatpak-app: instalar una app de Flathub desde apps/flatpak-apps.txt -----
# Baja el binario de Flathub y crea el .desktop. Sin args, lista las apps de la
# receta (~/.dotfiles/apps/flatpak-apps.txt).
flatpak-app() {
    local script="$HOME/.dotfiles/apps/build-flatpak-app.sh"
    local recipe="$HOME/.dotfiles/apps/flatpak-apps.txt"
    if [[ -z "$1" ]]; then
        echo "Uso: flatpak-app <id>   (instala la app de Flathub e integra al menu)"
        echo "Apps en la receta:"
        grep -vE '^[[:space:]]*#' "$recipe" 2>/dev/null | awk -F'|' 'NF{printf "  %-10s %s\n", $1, $2}'
        return 1
    fi
    bash "$script" "$1"
}

# --- update-all: actualizar todo lo que dnf NO cubre, en un solo comando -------
# dnf solo actualiza sus propios paquetes. Esta funcion recorre los demas
# gestores presentes (Flatpak, npm) ademas de dnf. Lo instalado por curl
# (oh-my-posh, zoxide, opencode, claude) suele autoactualizarse aparte.
update-all() {
    if command -v dnf &>/dev/null; then
        echo "==> dnf (paquetes del sistema)"
        sudo dnf upgrade -y
    fi
    if command -v flatpak &>/dev/null; then
        echo "==> flatpak (apps, p.ej. Teams)"
        flatpak update -y
    fi
    if command -v npm &>/dev/null; then
        echo "==> npm (paquetes globales, p.ej. codex)"
        npm update -g
    fi
    # OpenLogi se instala con 'rpm -i' desde un release de GitHub, no desde un
    # repo de dnf, asi que 'dnf upgrade' no lo ve. Comparamos la version instalada
    # contra el ultimo release y actualizamos solo si hay una nueva.
    if command -v openlogi &>/dev/null && command -v rpm &>/dev/null; then
        echo "==> openlogi (mouse MX, release de GitHub)"
        local _ol_cur _ol_new _ol_url _ol_tmp
        _ol_cur=$(rpm -q --qf '%{VERSION}' openlogi 2>/dev/null)
        _ol_new=$(curl -fsSL "https://api.github.com/repos/AprilNEA/OpenLogi/releases/latest" \
            | grep -oE '"tag_name": *"v?[^"]+"' | head -1 | grep -oE '[0-9][^"]*')
        if [[ -z "$_ol_new" ]]; then
            echo "   no se pudo consultar el ultimo release (sin red?), salteado"
        elif [[ "$_ol_cur" == "$_ol_new" ]]; then
            echo "   ya en la ultima ($_ol_cur)"
        else
            echo "   actualizando $_ol_cur -> $_ol_new"
            _ol_tmp=$(mktemp -d)
            _ol_url=$(curl -fsSL "https://api.github.com/repos/AprilNEA/OpenLogi/releases/latest" \
                | grep -oE 'https://[^"]+linux-amd64\.rpm' | head -1)
            if curl -fsSL "$_ol_url" -o "$_ol_tmp/openlogi.rpm"; then
                sudo rpm -U --replacepkgs "$_ol_tmp/openlogi.rpm" \
                    && systemctl --user restart openlogi-agent.service 2>/dev/null
            fi
            rm -rf "$_ol_tmp"
        fi
    fi
    echo "Listo. Nota: lazyssh (binario GitHub) y los instalados por curl"
    echo "(oh-my-posh, zoxide, opencode, claude) se actualizan aparte."
}

# ==============================================================================
# BLE.SH — paleta de colores (faces)
# ------------------------------------------------------------------------------
# Colores espejo de los PSReadLine -Colors de profile.ps1 (paridad Win/Linux):
#   Command #C79BFF · Parameter #7AB8FF · String #86E89A · Variable #FFDF61
#   Operator #56B6C2 · Error #FF7A7A · Comment #6B5448 · InlinePrediction #6B5448
# Naranja #D4874E para directorios (alineado con LS_COLORS di=172).
# No se llama 'ble-attach' aca: ble.sh ya adjunta solo en el primer prompt
# (metodo =prompt del source de arriba). Las faces se setean antes de ese
# primer prompt porque todo el bashrc corre primero.
# ==============================================================================

if [[ -n "${BLE_VERSION:-}" ]]; then
    # Comandos (funciones, builtins, alias, ejecutables, keywords) → purpura
    ble-face -s command_function 'fg=#C79BFF'
    ble-face -s command_builtin  'fg=#C79BFF'
    ble-face -s command_alias    'fg=#C79BFF'
    ble-face -s command_file     'fg=#C79BFF'
    ble-face -s command_keyword  'fg=#C79BFF,bold'
    # Directorios (cd a una carpeta) → naranja, como LS_COLORS
    ble-face -s command_directory  'fg=#D4874E'
    ble-face -s filename_directory 'fg=#D4874E'
    # Opciones/argumentos (--flag) → azul
    ble-face -s argument_option 'fg=#7AB8FF'
    # Strings (comillas) → verde
    ble-face -s syntax_quoted    'fg=#86E89A'
    ble-face -s syntax_quotation 'fg=#86E89A'
    # Variables / expansiones ($VAR, ${...}) → amarillo
    ble-face -s syntax_varname        'fg=#FFDF61'
    ble-face -s syntax_param_expansion 'fg=#FFDF61'
    # Operadores / delimitadores (| && > ;) → cyan
    ble-face -s syntax_delimiter 'fg=#56B6C2'
    # Errores (comando inexistente, sintaxis rota) → rojo
    ble-face -s syntax_error   'fg=#FF7A7A'
    ble-face -s argument_error 'fg=#FF7A7A'
    # Comentarios → tenue
    ble-face -s syntax_comment 'fg=#6B5448'
    # Autosugerencia del historial (espejo de InlinePrediction) → gris calido
    ble-face -s auto_complete 'fg=#6B5448'

    # Sugerencia desde el historial mientras escribis (como PSReadLine prediction)
    bleopt complete_auto_complete=1

    # No mostrar la marca '[ble: exit N]' tras un comando fallido: el estado lo
    # reporta el segmento 'status' de oh-my-posh (paridad con Windows, donde lo
    # hace el prompt y no PSReadLine). Evita el reporte duplicado del exit code.
    bleopt exec_errexit_mark=

    # El prompt de oh-my-posh es multilinea (linea de info + linea del ❯) y ademas
    # se arma desde PROMPT_COMMAND. Sin esto, ble.sh asume 1 linea al adjuntarse y
    # solo redibuja la ultima, dejando huerfana la linea de info → prompt duplicado
    # al abrir la terminal (se nota en Ptyxis/VTE).
    bleopt prompt_command_changes_layout=1
fi

