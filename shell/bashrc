# --- open: abrir directorio o archivo ---
open() {
    local target="${1:-.}"
    if [[ "$IS_WINDOWS" == true ]]; then
        cmd.exe //c start "" "$(cygpath -w "$target")" 2>/dev/null \
            || start "" "$target" 2>/dev/null
    else
        xdg-open "$target" 2>/dev/null &
    fi
}

