# ==============================================================================
# FZF (busqueda difusa — Ctrl+R para historial)
# ==============================================================================

if command -v fzf &>/dev/null; then
    # Cargar keybindings (Ctrl+R historial, Ctrl+T, Alt+C) + completions.
    # fzf >= 0.48 expone todo via 'fzf --zsh' (portable, sin adivinar rutas).
    if fzf --zsh &>/dev/null; then
        eval "$(fzf --zsh)"
    # Fallback para versiones viejas: las rutas varian por distro.
    elif [[ -f /usr/share/fzf/shell/key-bindings.zsh ]]; then   # Fedora 38+
        . /usr/share/fzf/shell/key-bindings.zsh
    elif [[ -f /usr/share/fzf/key-bindings.zsh ]]; then          # Arch / otros
        . /usr/share/fzf/key-bindings.zsh
    elif [[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]]; then  # Debian/Ubuntu
        . /usr/share/doc/fzf/examples/key-bindings.zsh
    elif [[ -f ~/.fzf.zsh ]]; then                               # instalador git
        . ~/.fzf.zsh
    fi

    export FZF_DEFAULT_OPTS="--height 40% --border rounded --layout=reverse --prompt ' ' \
--color=bg+:#3A2E2A,bg:#1E1A18,spinner:#D4874E,hl:#C79BFF \
--color=fg:#E8E0D4,header:#7AB8FF,info:#FFDF61,pointer:#D4874E \
