# ==============================================================================

# --- gup: set upstream de la rama actual ---
gup() {
    local branch
    branch="$(git rev-parse --abbrev-ref HEAD)"
    git branch --set-upstream-to="origin/$branch" "$branch"
}

# --- gpsu: push inicial con tracking ---
gpsu() {
    local branch
    branch="$(git rev-parse --abbrev-ref HEAD)"
    git push -u origin "$branch"
}

# --- gsync: fetch + pull rebase + autostash ---
gsync() {
    git fetch --all --prune
    git pull --rebase --autostash
}

# --- gsw: smart switch (crea rama si no existe local ni remota) ---
gsw() {
    local branch="$1"
    if [[ -z "$branch" ]]; then
        echo "Uso: gsw <rama>"
        return 1
    fi

    git fetch --prune &>/dev/null
    if git show-ref --verify --quiet "refs/heads/$branch"; then
        git switch "$branch"
    elif git show-ref --verify --quiet "refs/remotes/origin/$branch"; then
        git switch -t "origin/$branch"
    else
        git switch -c "$branch"
    fi
}

# --- gfixup: commit fixup ---
gfixup() {
    git commit --fixup "${1:-HEAD}"
}

# --- gundo: deshacer ultimo commit (mantiene cambios) ---
gundo() {
    git reset --soft HEAD~1
}

# --- gclean: limpiar archivos untracked ---
gclean() {
    echo "Archivos que se eliminarian:"
    git clean -fd --dry-run
    read -rp "Continuar? [y/N] " confirm
    [[ "$confirm" =~ ^[yY]$ ]] && git clean -fd
}

# --- gprune: limpiar ramas locales mergeadas ---
gprune() {
    git fetch --prune
    git branch --merged | grep -v '\*\|main\|master\|develop' | xargs -r git branch -d
}

# --- gcleanbranches: borrar ramas locales cuyo remote tracking ya no existe ---
gcleanbranches() {
    git fetch --prune
    local gone
    gone=$(git branch -vv | awk '/: gone\]/{print $1}')
    if [[ -z "$gone" ]]; then
        echo "Sin branches para limpiar."
        return 0
    fi
    echo "$gone" | xargs -r git branch -d
}

# --- gcoi: checkout interactivo con fzf ---
gcoi() {
    if ! command -v fzf &>/dev/null; then
        echo "fzf no esta instalado"
        return 1
    fi
    local branch
    branch=$(git branch --all | fzf --height 40% --border | sed 's/^[* ]*//' | sed 's|remotes/origin/||')
    [[ -n "$branch" ]] && git checkout "$branch"
}

# --- gwork: ir al directorio de trabajo ---
gwork() {
    local dir="${1:-$work}"
    cd "$dir" || return 1
}

