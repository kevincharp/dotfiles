*.bak*
.env
.DS_Store

# Ulauncher genera este CSS en runtime por cada tema (wrapper que importa
# theme.css). Es por-maquina y se regenera solo: no se versiona.
ulauncher/user-themes/*/generated.css

# Claude Code: versionar config importante, excluir temporal/sensible
# Estrategia: ignorar TODO en .claude/ y whitelistear solo lo portable.
# settings.local.json NO se versiona a proposito: es config por-maquina
# (permisos con rutas absolutas) — la convencion .local de Claude = no compartir.
.claude/*
!.claude/settings.json
!.claude/statusline.sh
!.claude/CLAUDE.md
# Configs propias (skills/agents/commands/hooks/estilos) — se versionan si existen
!.claude/skills/
!.claude/agents/
!.claude/commands/
!.claude/hooks/
!.claude/output-styles/
# Plugins: NO se versionan. installed_plugins.json y known_marketplaces.json
# llevan rutas absolutas por-SO incrustadas (installPath/installLocation), que
# difieren Linux/Windows y rompen /doctor al cruzarse. Son estado local que
# Claude Code regenera; la lista portable de plugins vive en settings.json
# (enabledPlugins). El cache se redescarga solo.
!.claude/worktrees/

# Lo sensible (ssh keys, identidades git, bookmarks) vive en el repo
# privado dotfiles-vault, NO en este repo publico.
