# --- port: lista el proceso escuchando en un puerto ---
port() {
    local p="${1:?Uso: port <numero>}"
    if command -v lsof &>/dev/null; then
        lsof -nP -iTCP:"$p" -sTCP:LISTEN
    else
        ss -ltnp "sport = :$p"
    fi
}

# --- killport: mata el proceso que escucha en un puerto ---
killport() {
    local p="${1:?Uso: killport <numero>}"
    local pid
    if command -v lsof &>/dev/null; then
        pid=$(lsof -nP -iTCP:"$p" -sTCP:LISTEN -t | head -n1)
    else
        pid=$(ss -ltnp "sport = :$p" 2>/dev/null | grep -oP 'pid=\K[0-9]+' | head -n1)
    fi
    if [[ -z "$pid" ]]; then
        echo "Nada escuchando en puerto $p"
        return 0
    fi
    kill -9 "$pid" && echo "Killed PID $pid (puerto $p)"
}

# --- killdev: mata procesos en puertos comunes de desarrollo ---
killdev() {
    local devports=(3000 3001 4200 5173 8080 8090 8443)
    for p in "${devports[@]}"; do
        killport "$p"
    done
}

# ==============================================================================
# GIT — CLONE + PERFILES DE IDENTIDAD
# ==============================================================================

# Identidades (nombre/email por perfil) viven en el vault privado.
# El bootstrap las copia a ~/.config/git-identities.sh. Si no estan, las
# funciones gclone/gset-profile/ginit avisan que falta el vault.
_GIT_IDENTITIES_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/git-identities.sh"
declare -gA GIT_IDENTITIES_NAME GIT_IDENTITIES_EMAIL
if [[ -f "$_GIT_IDENTITIES_FILE" ]]; then
    . "$_GIT_IDENTITIES_FILE"
fi

# Resuelve nombre/email de un perfil en las vars _gi_name/_gi_email.
# Devuelve 1 si el perfil no existe o el vault no esta cargado.
_resolve_identity() {
    local perfil="$1"
    _gi_name="${GIT_IDENTITIES_NAME[$perfil]:-}"
    _gi_email="${GIT_IDENTITIES_EMAIL[$perfil]:-}"
    if [[ -z "$_gi_name" || -z "$_gi_email" ]]; then
        if [[ ${#GIT_IDENTITIES_EMAIL[@]} -eq 0 ]]; then
            echo "Error: identidades git no cargadas (falta el vault: $_GIT_IDENTITIES_FILE)" >&2
        else
            echo "Error: perfil desconocido '$perfil'" >&2
            echo "Perfiles validos: ${!GIT_IDENTITIES_EMAIL[*]}" >&2
        fi
        return 1
    fi
    return 0
}

# Clonar repo y configurar identidad local automaticamente.
# Uso: gclone -p <perfil> -u <remoteUrl> [-d targetDir]
# Perfiles: cei_walle, work, kevincharp, kevincharp-gl
# Ejemplo: gclone -p work -u git@gitlab.com-xxx:grupo/repo.git
gclone() {
    local perfil="" remote_url="" target_dir=""

    # Parsear argumentos
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p|--perfil)  perfil="$2";     shift 2 ;;
            -u|--url)     remote_url="$2"; shift 2 ;;
            -d|--dir)     target_dir="$2"; shift 2 ;;
            *)
                echo "Uso: gclone -p <perfil> -u <remoteUrl> [-d targetDir]"
                echo "Perfiles: cei_walle, work, kevincharp, kevincharp-gl"
                return 1
                ;;
        esac
    done

    # Validar parametros
    if [[ -z "$perfil" || -z "$remote_url" ]]; then
        echo "Error: -p <perfil> y -u <remoteUrl> son obligatorios"
        echo "Uso: gclone -p <perfil> -u <remoteUrl> [-d targetDir]"
        return 1
    fi

    # Identidades (desde el vault via _resolve_identity)
    local name="" email=""
    _resolve_identity "$perfil" || return 1
    name="$_gi_name"; email="$_gi_email"

    # Determinar directorio destino
    local repo_name
    repo_name="$(basename "$remote_url" .git)"
    local clone_dir="${target_dir:-$(pwd)/$repo_name}"

    if [[ -d "$clone_dir" ]] && [[ -n "$(ls -A "$clone_dir" 2>/dev/null)" ]]; then
        echo "Error: el destino ya existe y no esta vacio: $clone_dir"
        return 1
    fi

    # Clonar
    echo "Clonando $remote_url en $clone_dir ..."
    if ! git clone "$remote_url" "$clone_dir"; then
        echo "Error: fallo el clone"
        return 1
    fi

    # Configurar identidad local
    (
        cd "$clone_dir" || return 1
        git config --local user.useConfigOnly true
        git config --local user.name          "$name"
        git config --local user.email         "$email"
        git config --local core.autocrlf      input
        git config --local pull.rebase        true
        git config --local rebase.autostash   true
    )

    echo ""
    echo "Repositorio: $repo_name"
    echo "Path:        $clone_dir"
    echo "Perfil:      $perfil"
    echo "User:        $name <$email>"
    echo "Remote:      $(cd "$clone_dir" && git remote get-url origin 2>/dev/null)"
}

# --- gset-profile: aplicar perfil git a repo ya existente ---
# Uso: gset-profile <perfil>
gset-profile() {
    local perfil="$1"
    if [[ -z "$perfil" ]]; then
        echo "Uso: gset-profile <perfil>"
        echo "Perfiles: cei_walle, work, kevincharp, kevincharp-gl"
        return 1
    fi

    if ! git rev-parse --is-inside-work-tree &>/dev/null; then
        echo "Error: no es un repo Git"
        return 1
    fi

    local name="" email=""
    _resolve_identity "$perfil" || return 1
    name="$_gi_name"; email="$_gi_email"

    git config --local user.name  "$name"
    git config --local user.email "$email"
    echo "Perfil '$perfil' aplicado: $name <$email>"
}

# Uso: ginit <perfil> [path]
# Inicia un repo git nuevo y aplica el perfil de identidad indicado.
ginit() {
    local perfil="$1"
    local path="${2:-$PWD}"

    if [[ -z "$perfil" ]]; then
        echo "Uso: ginit <perfil> [path]"
        echo "Perfiles: cei_walle, work, kevincharp, kevincharp-gl"
        return 1
    fi

    if [[ ! -d "$path" ]]; then
        echo "Error: $path no existe"
        return 1
    fi

    (
        cd "$path" || exit 1
        if [[ ! -d .git ]]; then
            git init -b main >/dev/null
        fi
        gset-profile "$perfil" || exit 1
        git config --local --unset-all pull.rebase        2>/dev/null
        git config --local --unset-all init.defaultbranch 2>/dev/null
        git config --local --unset-all core.autocrlf      2>/dev/null
        git config --local --unset-all core.editor        2>/dev/null
    )
}

# Uso: gremote <alias-ssh> <namespace/repo> [nombre-remote]
# Agrega o actualiza un remote usando un host alias SSH.
# Ejemplo: gremote gitlab.com-<mi-alias> mi-grupo/proyecto origin
gremote() {
    local alias_host="$1"
    local path_ns="$2"
    local name="${3:-origin}"

    if [[ -z "$alias_host" || -z "$path_ns" ]]; then
        echo "Uso: gremote <alias-ssh> <namespace/repo> [nombre-remote]"
        return 1
    fi

    local ssh="git@${alias_host}:${path_ns}.git"

    if git remote get-url "$name" &>/dev/null; then
        git remote set-url "$name" "$ssh"
    else
        git remote add "$name" "$ssh"
    fi
    echo "Remote '$name' → $ssh"
}

# ==============================================================================
# .ENV LOADER — cargar tokens desde ~/.env
# ==============================================================================

_load_dotenv() {
    local env_file="${1:-$HOME/.env}"
    [[ -f "$env_file" ]] || return 0

    while IFS= read -r line || [[ -n "$line" ]]; do
        # Ignorar lineas vacias y comentarios
        line="${line#"${line%%[![:space:]]*}"}"  # trim leading whitespace
        [[ -z "$line" || "$line" == \#* ]] && continue

        local key="${line%%=*}"
        local val="${line#*=}"
        # Trim comillas
        val="${val%\"}"
        val="${val#\"}"
        val="${val%\'}"
        val="${val#\'}"

        export "$key=$val"
    done < "$env_file"
}

_load_dotenv

